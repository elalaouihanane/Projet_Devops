# Copier vers backend/.env.testing puis ajuster (fichier .env.testing ignoré si absent du dépôt — l’ajouter localement).
# Laravel charge .env.testing quand APP_ENV=testing (ex. PHPUnit).
#
# Créer la base avant les tests :
#   mysql -h127.0.0.1 -uroot -p -e "CREATE DATABASE trendora_testing;"
# Même utilisateur que docker-compose : accorder les droits sur trendora_testing.
#
# PHPUnit dans le conteneur app : DB_HOST=db et souvent DB_DATABASE=trendora_testing (recommandé, pas la base dev).

APP_NAME=Trendora
APP_ENV=testing
# Copier la ligne APP_KEY depuis backend/.env (obligatoire pour les tests).
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=trendora_testing
DB_USERNAME=trendora_user
DB_PASSWORD=trendora_pass

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BROADCAST_CONNECTION=log
